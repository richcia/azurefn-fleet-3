      "type": "string",
      "value": "[format('fn-{0}', parameters('baseName'))]"
    },
    "functionPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', format('fn-{0}', parameters('baseName'))), '2023-01-01', 'full').identity.principalId]"
    }
