      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "tags": {
      "type": "object",
      "defaultValue": {}
    },
    "tenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]"
    },
    "softDeleteRetentionInDays": {
      "type": "int",
      "defaultValue": 90
    },
    "enablePurgeProtection": {
      "type": "bool",
      "defaultValue": true
    },
    "trapiCredentialSecretName": {
      "type": "string",
      "defaultValue": "trapi-credential"
