{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5989928908267544710"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    },
    "alertEmailAddress": {
      "type": "string",
      "metadata": {
        "description": "Email address to receive alert notifications"
      }
    },
    "appInsightsId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Application Insights component"
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Function App (used to scope alert queries)"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[format('ag-{0}', parameters('functionAppName'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "groupShortName": "FnAlerts",
        "enabled": true,
        "emailReceivers": [
          {
            "name": "owner",
            "emailAddress": "[parameters('alertEmailAddress')]",
            "useCommonAlertSchema": true
          }
        ]
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-{0}-exceptions', parameters('functionAppName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "Function App Exceptions Alert",
        "description": "Fires when function exceptions are detected in the last 24 hours",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT1H",
        "windowSize": "PT24H",
        "scopes": [
          "[parameters('appInsightsId')]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "[format('exceptions | where cloud_RoleName == ''{0}'' | summarize Count = count()', parameters('functionAppName'))]",
              "timeAggregation": "Count",
              "metricMeasureColumn": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}', parameters('functionAppName')))]"
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('ag-{0}', parameters('functionAppName')))]"
      ]
    }
  ]
}