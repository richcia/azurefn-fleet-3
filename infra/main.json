{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "4900362678556672289"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment location."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Existing Function App name to configure with Key Vault references."
      }
    },
    "functionAppPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal ID of the Function App system-assigned managed identity."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "[format('kv{0}', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Name of the Key Vault to create."
      }
    },
    "trapiFallbackSecretName": {
      "type": "string",
      "defaultValue": "trapi-fallback-credential",
      "metadata": {
        "description": "Secret name used for fallback TRAPI credentials in Key Vault references."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "1985-NY-Yankees",
        "owner": "rciapala"
      },
      "metadata": {
        "description": "Resource tags."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('functionAppName'), 'appsettings')]",
      "properties": {
        "KEY_VAULT_URI": "[reference(resourceId('Microsoft.Resources/deployments', 'keyVaultModule'), '2025-04-01').outputs.keyVaultUri.value]",
        "TRAPI_FALLBACK_CREDENTIAL": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/{1}/)', reference(resourceId('Microsoft.Resources/deployments', 'keyVaultModule'), '2025-04-01').outputs.keyVaultUri.value, parameters('trapiFallbackSecretName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'keyVaultModule')]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "keyVaultModule",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "functionAppPrincipalId": {
            "value": "[parameters('functionAppPrincipalId')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "14779393653469667100"
            }
          },
          "parameters": {
            "keyVaultName": {
              "type": "string",
              "metadata": {
                "description": "Name of the Azure Key Vault to create."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Deployment location for the Key Vault."
              }
            },
            "functionAppPrincipalId": {
              "type": "string",
              "metadata": {
                "description": "Principal ID of the Function App system-assigned managed identity."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Resource tags."
              }
            },
            "skuName": {
              "type": "string",
              "defaultValue": "premium",
              "allowedValues": [
                "premium"
              ],
              "metadata": {
                "description": "Key Vault SKU. Premium is used to satisfy zone-redundant SKU requirements."
              }
            }
          },
          "variables": {
            "keyVaultSecretsUserRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]"
          },
          "resources": [
            {
              "type": "Microsoft.KeyVault/vaults",
              "apiVersion": "2023-07-01",
              "name": "[parameters('keyVaultName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "tenantId": "[subscription().tenantId]",
                "sku": {
                  "family": "A",
                  "name": "[parameters('skuName')]"
                },
                "enableRbacAuthorization": true,
                "enabledForTemplateDeployment": false,
                "enabledForDiskEncryption": false,
                "enabledForDeployment": false,
                "publicNetworkAccess": "Enabled",
                "softDeleteRetentionInDays": 7,
                "enableSoftDelete": true,
                "enablePurgeProtection": true
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
              "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), parameters('functionAppPrincipalId'), variables('keyVaultSecretsUserRoleDefinitionId'))]",
              "properties": {
                "roleDefinitionId": "[variables('keyVaultSecretsUserRoleDefinitionId')]",
                "principalId": "[parameters('functionAppPrincipalId')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
              ]
            }
          ],
          "outputs": {
            "keyVaultId": {
              "type": "string",
              "value": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
            },
            "keyVaultName": {
              "type": "string",
              "value": "[parameters('keyVaultName')]"
            },
            "keyVaultUri": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "keyVaultId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'keyVaultModule'), '2025-04-01').outputs.keyVaultId.value]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'keyVaultModule'), '2025-04-01').outputs.keyVaultName.value]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'keyVaultModule'), '2025-04-01').outputs.keyVaultUri.value]"
    }
  }
}