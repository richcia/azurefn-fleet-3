{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "12791439741454678845"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for Function App resources"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to all resources"
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Function App"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the backing storage account for AzureWebJobsStorage identity-based connection"
      }
    },
    "applicationInsightsConnectionString": {
      "type": "string",
      "metadata": {
        "description": "Connection string from the monitoring module output"
      }
    },
    "keyVaultUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Key Vault URI used to build TRAPI setting references"
      }
    },
    "trapiEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "TRAPI endpoint value when not using Key Vault references"
      }
    },
    "trapiAuthScope": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "TRAPI auth scope value when not using Key Vault references"
      }
    },
    "trapiEndpointSecretName": {
      "type": "string",
      "defaultValue": "trapi-endpoint",
      "metadata": {
        "description": "Key Vault secret name for TRAPI endpoint"
      }
    },
    "trapiAuthScopeSecretName": {
      "type": "string",
      "defaultValue": "trapi-auth-scope",
      "metadata": {
        "description": "Key Vault secret name for TRAPI auth scope"
      }
    },
    "stagingTrapiEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional staging slot override for TRAPI endpoint"
      }
    },
    "stagingTrapiAuthScope": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional staging slot override for TRAPI auth scope"
      }
    }
  },
  "variables": {
    "productionTrapiEndpoint": "[if(empty(parameters('keyVaultUri')), parameters('trapiEndpoint'), format('@Microsoft.KeyVault(SecretUri={0}secrets/{1}/)', parameters('keyVaultUri'), parameters('trapiEndpointSecretName')))]",
    "productionTrapiAuthScope": "[if(empty(parameters('keyVaultUri')), parameters('trapiAuthScope'), format('@Microsoft.KeyVault(SecretUri={0}secrets/{1}/)', parameters('keyVaultUri'), parameters('trapiAuthScopeSecretName')))]",
    "stagingTrapiEndpointValue": "[if(empty(parameters('stagingTrapiEndpoint')), variables('productionTrapiEndpoint'), parameters('stagingTrapiEndpoint'))]",
    "stagingTrapiAuthScopeValue": "[if(empty(parameters('stagingTrapiAuthScope')), variables('productionTrapiAuthScope'), parameters('stagingTrapiAuthScope'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[format('{0}-plan', parameters('functionAppName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "Python|3.11",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('applicationInsightsConnectionString')]"
            },
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('storageAccountName')]"
            },
            {
              "name": "TRAPI_ENDPOINT",
              "value": "[variables('productionTrapiEndpoint')]"
            },
            {
              "name": "TRAPI_AUTH_SCOPE",
              "value": "[variables('productionTrapiAuthScope')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/slots",
      "apiVersion": "2022-09-01",
      "name": "[format('{0}/staging', parameters('functionAppName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "Python|3.11",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('applicationInsightsConnectionString')]"
            },
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('storageAccountName')]"
            },
            {
              "name": "TRAPI_ENDPOINT",
              "value": "[variables('stagingTrapiEndpointValue')]"
            },
            {
              "name": "TRAPI_AUTH_SCOPE",
              "value": "[variables('stagingTrapiAuthScopeValue')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('functionAppName')))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2022-09-01",
      "name": "[format('{0}/slotConfigNames', parameters('functionAppName'))]",
      "properties": {
        "appSettingNames": [
          "TRAPI_ENDPOINT",
          "TRAPI_AUTH_SCOPE"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2022-09-01', 'full').identity.principalId]"
    },
    "functionAppNameOut": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    }
  }
}