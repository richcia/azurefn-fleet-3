      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    },
    "baseName": {
      "type": "string",
      "metadata": {
        "description": "Base name used to derive resource names"
      }
    },
    "hostStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the host storage account for Functions runtime"
      }
    },
    "appInsightsConnectionString": {
      "type": "string",
      "metadata": {
        "description": "Application Insights connection string"
      }
    },
    "dataStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the dedicated data storage account"
      }
    },
    "keyVaultUri": {
      "type": "string",
      "metadata": {
        "description": "Key Vault URI for Key Vault references"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[format('asp-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[format('fn-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('asp-{0}', parameters('baseName')))]",
        "reserved": true,
        "siteConfig": {
          "linuxFxVersion": "Python|3.11",
          "functionAppScaleLimit": 1,
          "appSettings": [
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
