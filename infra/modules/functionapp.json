{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "4544360154365955098"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for the Function App."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Function App name."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "metadata": {
        "description": "App Service plan name for Linux Consumption hosting."
      }
    },
    "hostStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Host storage account name for identity-based AzureWebJobsStorage configuration."
      }
    },
    "applicationInsightsConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Application Insights connection string."
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Key Vault name used for app-setting references."
      }
    },
    "trapiEndpointSecretName": {
      "type": "string",
      "defaultValue": "TRAPI-ENDPOINT",
      "metadata": {
        "description": "Key Vault secret name for TRAPI endpoint."
      }
    },
    "trapiAuthScopeSecretName": {
      "type": "string",
      "defaultValue": "TRAPI-AUTH-SCOPE",
      "metadata": {
        "description": "Key Vault secret name for TRAPI auth scope."
      }
    },
    "dataStorageAccountNameSecretName": {
      "type": "string",
      "defaultValue": "DATA-STORAGE-ACCOUNT-NAME",
      "metadata": {
        "description": "Key Vault secret name for data storage account name."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Optional resource tags."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": true
      },
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[parameters('tags')]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "Python|3.11",
          "appSettings": [
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('hostStorageAccountName')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[parameters('applicationInsightsConnectionString')]"
            },
            {
              "name": "TRAPI_ENDPOINT",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName={1})', parameters('keyVaultName'), parameters('trapiEndpointSecretName'))]"
            },
            {
              "name": "TRAPI_AUTH_SCOPE",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName={1})', parameters('keyVaultName'), parameters('trapiAuthScopeSecretName'))]"
            },
            {
              "name": "DATA_STORAGE_ACCOUNT_NAME",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName={1})', parameters('keyVaultName'), parameters('dataStorageAccountNameSecretName'))]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
    },
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "principalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]"
    }
  }
}