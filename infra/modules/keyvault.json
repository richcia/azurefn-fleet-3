      "value": "[if(parameters('createTrapiCredentialSecret'), format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', parameters('name')), '2023-07-01').vaultUri, parameters('trapiCredentialSecretName')), '')]"
    }
  }
